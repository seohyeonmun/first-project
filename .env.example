# 광주 버스 api 인증키
BUS_API_KEY=여기에_API_KEY_입력
# --- Wake word (openWakeWord) ---
WAKEWORD_TEXT=헤이알렉스
# 기본 모델 키(ex: alexa, hey_jarvis, hey_mycroft)
OWW_DEFAULT_MODEL=alexa
# 커스텀 모델(.onnx/.tflite) 경로. 비우면 기본 모델 사용.
OWW_MODEL_PATH=
OWW_THRESHOLD=0.5
# 1이면 Silero VAD로 KWS 게이팅(말소리 구간에서만 웨이크 탐지)
USE_SILERO_VAD=1
SILERO_VAD_THRESHOLD=0.5
SILERO_VAD_MIN_SPEECH_FRAMES=1
SILERO_VAD_MIN_SILENCE_FRAMES=6

# --- Recording / STT ---
# 무음이 SILENCE_SECONDS 이상 지속되면 녹음 종료
SILENCE_SECONDS=3
SILENCE_THRESHOLD=0.01
MIN_RECORD_SECONDS=0.5
MAX_RECORD_SECONDS=120
CONFIRM_LISTEN_SECONDS=2
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=ko
WHISPER_KOREAN_ONLY=1
BUS_KEYWORD_ONLY_MODE=1
BUS_KEYWORD_SILENCE_SECONDS=0.7
BUS_KEYWORD_MIN_RECORD_SECONDS=0.2
BUS_KEYWORD_MAX_RECORD_SECONDS=1.8

# --- Direct LLM via local OpenClaw CLI ---
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION_PREFIX=voice-mvp

# --- Runtime ---
REPLY_TIMEOUT_SEC=45
TTS_VOICE=Yuna
# 1이면 STT/LLM/TTS 단계별 지연 로그 출력
VOICE_TIMING_LOG=1

# --- TTS backend (GPT-SoVITS only) ---
# gpt_sovits_api(권장) | gpt_sovits(local)
TTS_BACKEND=gpt_sovits_api
# 너무 짧은 확인 멘트는 say로 빠르게 처리
TTS_JARVIS_MIN_LEN=8

# --- GPT-SoVITS ---
GPT_SOVITS_DIR=/Volumes/t7/openclaw-storage/projects/GPT-SoVITS
GPT_SOVITS_PYTHON=/Volumes/t7/openclaw-storage/projects/GPT-SoVITS/.venv/bin/python
GPT_SOVITS_GPT_MODEL=GPT_SoVITS/pretrained_models/s1v3.ckpt
GPT_SOVITS_SOVITS_MODEL=/Volumes/t7/openclaw-storage/projects/GPT-SoVITS/SoVITS_weights_v2Pro/khs_fast_20260423_e4_s440.pth
GPT_SOVITS_REF_AUDIO=/absolute/path/to/reference.wav
GPT_SOVITS_REF_TEXT=핵심은 다음 점검 시점은 1시간 내에 확인 가능이에요.
GPT_SOVITS_PROMPT_LANGUAGE=all_ko
GPT_SOVITS_TEXT_LANGUAGE=all_ko
GPT_SOVITS_HOW_TO_CUT=不切
GPT_SOVITS_TEXT_SPLIT_METHOD=cut0
GPT_SOVITS_TOP_K=20
GPT_SOVITS_TOP_P=0.6
GPT_SOVITS_TEMPERATURE=0.6
GPT_SOVITS_SPEED=1.0
GPT_SOVITS_PAUSE_SECOND=0.3
GPT_SOVITS_SAMPLE_STEPS=4
GPT_SOVITS_PARALLEL_INFER=1
GPT_SOVITS_BATCH_SIZE=1
GPT_SOVITS_BATCH_THRESHOLD=0.75
GPT_SOVITS_SPLIT_BUCKET=1
GPT_SOVITS_REPETITION_PENALTY=1.35
GPT_SOVITS_FRAGMENT_INTERVAL=0.3
GPT_SOVITS_STREAMING_MODE=False
GPT_SOVITS_SUPER_SAMPLING=0
GPT_SOVITS_SEED=-1

# 상시 API 모드 (권장: 모델 warm 유지로 지연 감소)
GPT_SOVITS_USE_API=1
GPT_SOVITS_API_URL=http://127.0.0.1:9880
GPT_SOVITS_API_TIMEOUT=90